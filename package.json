{
  "name": "hr-analytics-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "serve": "node scripts/serve.mjs",
    "test": "node scripts/test.mjs",
    "typecheck": "tsc --noEmit",
    "check:size": "node scripts/check-size.mjs",
    "sbom": "npm sbom --sbom-format cyclonedx",
    "verify": "npm run typecheck && npm test && npm run build && npm run check:size",
    "sample-data": "node scripts/generate-sample-data.mjs",
    "sample-workspace": "node scripts/build-sample-workspace.mjs",
    "embed-demo": "node scripts/embed-demo.mjs",
    "dev": "vite",
    "preview": "vite preview",
    "build:vite": "tsc -b && vite build",
    "test:vitest": "vitest run"
  },
  "dependencies": {
    "arquero": "^8.0.3",
    "pako": "^2.1.0",
    "plotly.js-basic-dist-min": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild-wasm": "^0.28.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^2.1.8"
  }
}
